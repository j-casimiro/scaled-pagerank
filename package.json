{
  "name": "wikipedia-pagerank-typescript",
  "version": "1.0.0",
  "description": "TypeScript migration of Wikipedia PageRank search engine",
  "main": "engine.js",
  "scripts": {
    "crawl": "npx tsx src/crawler.ts",
    "build": "npx tsc src/engine.ts --target es6 --skipLibCheck --outFile dist/engine.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
